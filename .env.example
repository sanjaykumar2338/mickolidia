APP_NAME=Wolforix
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

ADMIN_USERNAME=admin
ADMIN_PASSWORD=wolforix-admin
ADMIN_REALM="Wolforix Admin"

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=wolforix
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

STRIPE_KEY=pk_test_your_publishable_key
STRIPE_SECRET=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=
LAUNCH_PROMO_CODE=Wolforix2026

TRADING_PLATFORM_DEFAULT=ctrader
TRADING_SYNC_ENABLED=false
TRADING_SYNC_USE_QUEUE=true
TRADING_SYNC_QUEUE=trading-sync
TRADING_SYNC_CHUNK_SIZE=50
TRADING_SYNC_CRON="*/15 * * * *"

CTRADER_SYNC_ENABLED=false
CTRADER_USE_MOCK_DATA=false
CTRADER_BASE_URL=
CTRADER_ACCESS_TOKEN=
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
CTRADER_ACCOUNT_ENDPOINT=/accounts/{account}
CTRADER_TIMEOUT=10
CTRADER_ENVIRONMENT=demo

ECONOMIC_CALENDAR_PROVIDER=tradingeconomics
ECONOMIC_CALENDAR_TIMEZONE=Europe/Berlin
ECONOMIC_CALENDAR_DEFAULT_RANGE=this_week
TRADING_ECONOMICS_BASE_URL=https://api.tradingeconomics.com
TRADING_ECONOMICS_API_KEY=
FMP_API_KEY=
ECONODAY_API_KEY=
