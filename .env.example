APP_NAME=Wolforix
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

ADMIN_USERNAME=admin
ADMIN_PASSWORD=wolforix-admin
ADMIN_REALM="Wolforix Admin"

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=wolforix
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_AUTOMATED_FROM_ADDRESS="noreply@wolforix.com"
MAIL_AUTOMATED_FROM_NAME="Wolforix Notifications"
MAIL_AUTOMATED_REPLY_TO_ADDRESS="support@wolforix.com"
MAIL_AUTOMATED_REPLY_TO_NAME="Wolforix Support"
SUPPORT_EMAIL="support@wolforix.com"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

STRIPE_KEY=pk_test_your_publishable_key
STRIPE_SECRET=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_REDIRECT_URI=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_BASE_URL=
PAYPAL_WEBHOOK_ID=
PAYPAL_TIMEOUT=15
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT=20
OPENAI_TTS_ENABLED=true
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=onyx
OPENAI_TTS_FORMAT=mp3
OPENAI_TTS_SPEED=0.94
MT5_INGESTION_TOKEN=
MT5_SYNC_ENABLED=true
MT5_SYNC_LIVE_SECONDS=15
MT5_SYNC_RECENT_SECONDS=60
LAUNCH_PROMO_CODE=Wolforix2026

TRADING_PLATFORM_DEFAULT=ctrader
TRADING_SYNC_ENABLED=false
TRADING_SYNC_USE_QUEUE=true
TRADING_SYNC_QUEUE=trading-sync
TRADING_SYNC_CHUNK_SIZE=50
TRADING_SYNC_CRON="*/5 * * * *"

CTRADER_SYNC_ENABLED=false
CTRADER_USE_MOCK_DATA=false
CTRADER_BROKER_NAME="IC Markets"
CTRADER_AUTH_URL=https://id.ctrader.com/my/settings/openapi/grantingaccess/
CTRADER_TOKEN_URL=https://openapi.ctrader.com/apps/token
CTRADER_BASE_URL=https://openapi.ctrader.com
CTRADER_ACCESS_TOKEN=
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
CTRADER_REDIRECT_URI=https://wolforix.com/auth/callback
CTRADER_SCOPE=accounts
CTRADER_ACCOUNT_ENDPOINT=/accounts/{account}
CTRADER_TIMEOUT=15
CTRADER_ENVIRONMENT=demo
CTRADER_TRANSPORT_SCHEME=wss
CTRADER_JSON_PORT=5036
CTRADER_DEMO_HOST=demo.ctraderapi.com
CTRADER_LIVE_HOST=live.ctraderapi.com
CTRADER_HISTORY_DAYS=90
CTRADER_HISTORY_MAX_ROWS=500
CTRADER_LOG_LEVEL=debug

ECONOMIC_CALENDAR_PROVIDER=tradingeconomics
ECONOMIC_CALENDAR_TIMEZONE=Europe/Berlin
ECONOMIC_CALENDAR_DEFAULT_RANGE=this_week
TRADING_ECONOMICS_BASE_URL=https://api.tradingeconomics.com
